{
	"id": "crawl_self_link_no_loop",
	"description": "Page linking to itself does not cause infinite crawl loop",
	"tags": ["crawl", "dedup"],
	"mock_responses": [
		{
			"path": "/",
			"headers": { "content-type": "text/html" },
			"body_inline": "<html><body><a href=\"/\">Self</a><a href=\"/other\">Other</a></body></html>"
		},
		{
			"path": "/other",
			"headers": { "content-type": "text/html" },
			"body_inline": "<html><body><h1>Other</h1></body></html>"
		}
	],
	"config": {
		"engine_mode": true,
		"max_depth": 1,
		"max_concurrent": 1
	},
	"assertions": {
		"crawl": {
			"pages_crawled": 2
		}
	}
}
