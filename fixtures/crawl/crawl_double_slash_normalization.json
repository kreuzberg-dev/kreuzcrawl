{
  "id": "crawl_double_slash_normalization",
  "description": "Normalizes double slashes in URL paths (//page to /page)",
  "tags": ["crawl", "normalization"],
  "mock_responses": [
    {
      "path": "/",
      "method": "GET",
      "status_code": 200,
      "headers": {"content-type": "text/html; charset=utf-8"},
      "body_inline": "<html><body><a href=\"//page\">Double Slash</a><a href=\"/page\">Normal</a></body></html>"
    },
    {
      "path": "/page",
      "method": "GET",
      "status_code": 200,
      "headers": {"content-type": "text/html; charset=utf-8"},
      "body_inline": "<html><body><h1>Page</h1></body></html>"
    }
  ],
  "config": {
    "max_depth": 1,
    "respect_robots_txt": false
  },
  "assertions": {
    "crawl": {
      "unique_normalized_urls": 2
    }
  }
}
