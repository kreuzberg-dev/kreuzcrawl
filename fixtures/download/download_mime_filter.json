{
	"id": "download_mime_filter",
	"description": "Only download documents matching specified MIME types (PDF only, not DOCX)",
	"tags": ["download", "mime-type", "filter"],
	"input": {
		"mock_responses": [
			{
				"status_code": 200,
				"headers": {
					"content-type": "application/pdf"
				},
				"body_file": "pdf/sample.pdf"
			}
		],
		"config": {
			"respect_robots_txt": false,
			"download_documents": true,
			"document_mime_types": ["application/pdf"]
		}
	},
	"assertions": [
		{
			"type": "equals",
			"field": "downloaded_document.mime_type",
			"value": "application/pdf"
		}
	]
}
