{
	"id": "error_partial_response",
	"description": "Handles incomplete or truncated HTTP response",
	"tags": ["error", "network"],
	"skip": {
		"languages": ["wasm", "c"],
		"reason": "requires mock HTTP server; Wiremock overrides content-length header; needs raw TCP or custom mock"
	},
	"input": {
		"mock_responses": [
			{
				"status_code": 200,
				"headers": {
					"content-type": "text/html; charset=utf-8",
					"content-length": "99999"
				},
				"body_inline": "<html><body><h1>Truncated"
			}
		],
		"config": {
			"respect_robots_txt": false
		}
	},
	"assertions": [
		{
			"type": "error"
		},
		{
			"type": "error",
			"value": "data_loss"
		}
	]
}
