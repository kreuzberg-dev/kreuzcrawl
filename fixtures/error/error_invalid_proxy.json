{
	"id": "error_invalid_proxy",
	"description": "Proxy pointing to unreachable address causes connection error during scrape",
	"tags": ["proxy", "error"],
	"mock_response": {
		"status_code": 200,
		"body_inline": "<html></html>"
	},
	"config": {
		"proxy": {
			"url": "http://127.0.0.1:1"
		},
		"request_timeout_ms": 2000
	},
	"assertions": {
		"error": {
			"is_error": true,
			"error_type": "connection"
		}
	}
}
