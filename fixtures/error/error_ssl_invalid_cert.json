{
  "id": "error_ssl_invalid_cert",
  "description": "Handles SSL certificate validation error",
  "tags": ["error", "ssl"],
  "config": {
    "respect_robots_txt": false,
    "request_timeout_ms": 5000
  },
  "assertions": {
    "error": {
      "is_error": true,
      "error_type": "ssl"
    }
  },
  "skip": {
    "requires_network": true,
    "notes": "Requires TLS handshake to fail"
  }
}
