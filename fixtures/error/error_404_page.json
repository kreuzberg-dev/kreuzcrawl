{
	"id": "error_404_page",
	"description": "Handles 404 response correctly",
	"tags": ["error"],
	"skip": {
		"languages": ["wasm", "c"],
		"reason": "requires mock HTTP server"
	},
	"input": {
		"mock_responses": [
			{
				"status_code": 404,
				"headers": {
					"content-type": "text/html; charset=utf-8"
				},
				"body_inline": "<html><body><h1>404 Not Found</h1></body></html>"
			}
		]
	},
	"assertions": [
		{
			"type": "equals",
			"field": "status_code",
			"value": 404
		},
		{
			"type": "error"
		},
		{
			"type": "error",
			"value": "not_found"
		}
	]
}
