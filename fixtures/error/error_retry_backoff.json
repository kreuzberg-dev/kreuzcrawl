{
	"id": "error_retry_backoff",
	"description": "Implements exponential backoff when retrying failed requests",
	"tags": ["error", "retry", "backoff"],
	"skip": {
		"languages": ["wasm", "c"],
		"reason": "requires mock HTTP server"
	},
	"input": {
		"mock_responses": [
			{
				"status_code": 429,
				"headers": {
					"content-type": "text/html",
					"retry-after": "1"
				},
				"body_inline": "<html><body>Too Many Requests</body></html>"
			}
		],
		"config": {
			"respect_robots_txt": false,
			"retry_count": 3,
			"retry_codes": [429]
		}
	},
	"assertions": [
		{
			"type": "error"
		},
		{
			"type": "error",
			"value": "rate_limited"
		}
	]
}
