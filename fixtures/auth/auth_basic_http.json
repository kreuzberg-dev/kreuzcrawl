{
	"id": "auth_basic_http",
	"description": "Sends HTTP Basic authentication header",
	"tags": ["auth", "basic"],
	"mock_response": {
		"status_code": 200,
		"headers": { "content-type": "text/html; charset=utf-8" },
		"body_inline": "<html><body><h1>Authenticated Page</h1></body></html>"
	},
	"config": {
