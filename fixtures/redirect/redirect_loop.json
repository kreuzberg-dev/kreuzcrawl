{
	"id": "redirect_loop",
	"description": "Detects redirect loop (A -> B -> A) and returns error",
	"tags": [
		"redirect",
		"error"
	],
	"skip": {
		"languages": [
			"wasm",
			"c"
		],
		"reason": "requires mock HTTP server"
	},
	"input": {
		"mock_responses": [
			{
				"path": "/a",
				"method": "GET",
				"status_code": 302,
				"headers": {
					"location": "/b"
				},
				"body_inline": ""
			},
			{
				"path": "/b",
				"method": "GET",
				"status_code": 302,
				"headers": {
					"location": "/a"
				},
				"body_inline": ""
			}
		],
		"config": {
			"respect_robots_txt": false
		}
	},
	"assertions": [
		{
			"type": "equals",
			"field": "is_error",
			"value": true
		}
	]
}
