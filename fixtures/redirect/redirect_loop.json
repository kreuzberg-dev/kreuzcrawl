{
	"id": "redirect_loop",
	"description": "Detects redirect loop (A -> B -> A) and returns error",
	"tags": ["redirect", "error"],
	"mock_responses": [
		{
			"path": "/a",
			"method": "GET",
			"status_code": 302,
			"headers": { "location": "/b" },
			"body_inline": ""
		},
		{
			"path": "/b",
			"method": "GET",
			"status_code": 302,
			"headers": { "location": "/a" },
			"body_inline": ""
		}
	],
	"config": {
		"respect_robots_txt": false
	},
	"assertions": {
		"redirect": {
			"is_error": true
		}
	}
}
