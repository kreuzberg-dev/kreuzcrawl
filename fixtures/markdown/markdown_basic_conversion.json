{
	"id": "markdown_basic_conversion",
	"description": "HTML is always converted to markdown alongside raw HTML",
	"tags": [
		"markdown"
	],
	"skip": {
		"languages": [
			"wasm",
			"c"
		],
		"reason": "requires mock HTTP server"
	},
	"input": {
		"mock_responses": [
			{
				"status_code": 200,
				"headers": {
					"content-type": "text/html; charset=utf-8"
				},
				"body_inline": "<html><head><title>Test</title></head><body><h1>Hello World</h1><p>This is a paragraph.</p></body></html>"
			}
		],
		"config": {
			"engine_mode": true
		}
	},
	"assertions": [
		{
			"type": "equals",
			"field": "status_code",
			"value": 200
		},
		{
			"type": "equals",
			"field": "metadata.title",
			"value": "Test"
		},
		{
			"type": "not_empty",
			"field": "html"
		},
		{
			"type": "not_empty",
			"field": "markdown"
		},
		{
			"type": "contains",
			"field": "markdown",
			"value": "Hello World"
		}
	]
}
