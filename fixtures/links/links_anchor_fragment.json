{
	"id": "links_anchor_fragment",
	"description": "Identifies fragment-only links as anchor type",
	"tags": ["links"],
	"skip": {
		"languages": ["wasm", "c"],
		"reason": "requires mock HTTP server"
	},
	"input": {
		"mock_responses": [
			{
				"status_code": 200,
				"headers": {
					"content-type": "text/html; charset=utf-8"
				},
				"body_inline": "<html><body><a href=\"#section-1\">Section 1</a><a href=\"/about\">About</a></body></html>"
			}
		]
	},
	"assertions": [
		{
			"type": "contains_all",
			"field": "links[].link_type",
			"values": ["anchor"]
		}
	]
}
