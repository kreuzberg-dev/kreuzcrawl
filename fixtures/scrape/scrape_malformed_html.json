{
  "id": "scrape_malformed_html",
  "description": "Gracefully handles broken HTML without crashing",
  "tags": ["scrape", "edge-case"],
  "mock_response": {
    "status_code": 200,
    "headers": { "content-type": "text/html; charset=utf-8" },
    "body_file": "html/malformed.html"
  },
  "assertions": {
    "status_code": 200,
    "html_not_empty": true,
    "metadata": {
      "description_contains": "broken HTML"
    }
  }
}
