{
  "id": "scrape_image_sources",
  "description": "Extracts images from img, picture, og:image, twitter:image",
  "tags": ["scrape", "images"],
  "mock_response": {
    "status_code": 200,
    "headers": { "content-type": "text/html; charset=utf-8" },
    "body_file": "html/image_sources.html"
  },
  "assertions": {
    "status_code": 200,
    "images": { "min_count": 5 },
    "og": { "og_image": "https://example.com/images/og-hero.jpg" }
  }
}
