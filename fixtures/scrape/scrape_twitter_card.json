{
	"id": "scrape_twitter_card",
	"description": "Extracts Twitter Card metadata from a page",
	"tags": ["scrape", "metadata", "twitter"],
	"mock_response": {
		"status_code": 200,
		"headers": { "content-type": "text/html; charset=utf-8" },
		"body_file": "html/twitter_card.html"
	},
	"assertions": {
		"status_code": 200,
		"twitter": {
			"has_twitter_card": true,
			"twitter_card_type": "summary_large_image",
			"twitter_title": "New Product Launch"
		}
	}
}
