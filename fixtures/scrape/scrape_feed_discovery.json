{
	"id": "scrape_feed_discovery",
	"description": "Discovers RSS, Atom, and JSON feed links",
	"tags": [
		"scrape",
		"feeds"
	],
	"skip": {
		"languages": [
			"wasm",
			"c"
		],
		"reason": "requires mock HTTP server"
	},
	"input": {
		"mock_responses": [
			{
				"status_code": 200,
				"headers": {
					"content-type": "text/html; charset=utf-8"
				},
				"body_file": "html/rss_atom_feeds.html"
			}
		]
	},
	"assertions": [
		{
			"type": "equals",
			"field": "status_code",
			"value": 200
		},
		{
			"type": "equals",
			"field": "feeds.rss.length",
			"value": 1
		},
		{
			"type": "equals",
			"field": "feeds.atom.length",
			"value": 1
		},
		{
			"type": "equals",
			"field": "feeds.json_feed.length",
			"value": 1
		}
	]
}
