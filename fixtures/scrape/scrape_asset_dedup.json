{
	"id": "scrape_asset_dedup",
	"description": "Same asset linked twice results in one download with one unique hash",
	"tags": [
		"scrape",
		"assets"
	],
	"skip": {
		"languages": [
			"wasm",
			"c"
		],
		"reason": "requires mock HTTP server"
	},
	"input": {
		"mock_responses": [
			{
				"path": "/",
				"status_code": 200,
				"headers": {
					"content-type": "text/html; charset=utf-8"
				},
				"body_file": "html/page_with_dedup_assets.html"
			},
			{
				"path": "/assets/style.css",
				"status_code": 200,
				"headers": {
					"content-type": "text/css"
				},
				"body_file": "assets/style.css"
			},
			{
				"path": "/assets/photo.jpg",
				"status_code": 200,
				"headers": {
					"content-type": "image/jpeg"
				},
				"body_file": "assets/photo.jpg"
			}
		],
		"config": {
			"download_assets": true
		}
	},
	"assertions": [
		{
			"type": "equals",
			"field": "status_code",
			"value": 200
		},
		{
			"type": "equals",
			"field": "assets.length",
			"value": 2
		},
		{
			"type": "equals",
			"field": "assets.unique_hashes",
			"value": 2
		}
	]
}
