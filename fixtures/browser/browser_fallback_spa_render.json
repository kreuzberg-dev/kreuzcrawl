{
	"id": "browser_fallback_spa_render",
	"description": "Browser auto re-fetches SPA shell when JS rendering is detected",
	"tags": ["browser", "fallback", "spa"],
	"skip": {
		"languages": ["wasm"],
		"reason": "wasm32 has no chromium backend"
	},
	"input": {
		"mock_responses": [
			{
				"status_code": 200,
				"headers": {
					"content-type": "text/html; charset=utf-8"
				},
				"body_file": "html/spa_react_shell.html"
			}
		],
		"config": {
			"browser": {
				"mode": "always"
			}
		}
	},
	"assertions": [
		{
			"type": "equals",
			"field": "js_render_hint",
			"value": true
		},
		{
			"type": "equals",
			"field": "browser_used",
			"value": true
		}
	]
}
