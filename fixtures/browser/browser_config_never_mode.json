{
  "id": "browser_config_never_mode",
  "description": "Browser mode 'never' prevents browser fallback even for SPA shell content",
  "tags": ["browser", "config"],
  "mock_response": {
    "status_code": 200,
    "headers": {"content-type": "text/html; charset=utf-8"},
    "body_file": "html/spa_react_shell.html"
  },
  "config": {
    "browser_mode": "never"
  },
  "assertions": {
    "status_code": 200,
    "browser": {
      "js_render_hint": true,
      "browser_used": false
    }
  }
}
