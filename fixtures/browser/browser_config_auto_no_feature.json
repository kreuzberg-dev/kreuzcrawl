{
	"id": "browser_config_auto_no_feature",
	"description": "Browser mode 'never' prevents browser use even when JS render hint is set",
	"tags": ["browser", "config"],
	"input": {
		"mock_responses": [
			{
				"status_code": 200,
				"headers": {
					"content-type": "text/html; charset=utf-8"
				},
				"body_file": "html/spa_react_shell.html"
			}
		],
		"config": {
			"browser": {
				"mode": "never"
			}
		}
	},
	"assertions": [
		{
			"type": "equals",
			"field": "status_code",
			"value": 200
		},
		{
			"type": "equals",
			"field": "js_render_hint",
			"value": true
		},
		{
			"type": "equals",
			"field": "browser_used",
			"value": false
		}
	]
}
