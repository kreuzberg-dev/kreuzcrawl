{
  "id": "browser_detect_react_shell",
  "description": "Detects React SPA shell with empty #root div as needing JS rendering",
  "tags": ["browser", "detection"],
  "mock_response": {
    "status_code": 200,
    "headers": {"content-type": "text/html; charset=utf-8"},
    "body_file": "html/spa_react_shell.html"
  },
  "assertions": {
    "status_code": 200,
    "html_not_empty": true,
    "browser": {
      "js_render_hint": true,
      "browser_used": false
    }
  }
}
