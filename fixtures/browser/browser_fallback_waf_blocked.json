{
	"id": "browser_fallback_waf_blocked",
	"description": "Browser fallback triggers when WAF blocks the HTTP request (Cloudflare 403)",
	"tags": ["browser", "fallback", "waf"],
	"skip": {
		"languages": ["wasm", "c", "go", "java", "csharp"],
		"reason": "requires browser feature; requires browser; Requires a running Chrome/Chromium instance"
	},
	"input": {
		"mock_responses": [
			{
				"status_code": 403,
				"headers": {
					"content-type": "text/html",
					"server": "cloudflare"
				},
				"body_file": "error/cloudflare_challenge.html"
			}
		],
		"config": {
			"browser_mode": "auto"
		}
	},
	"assertions": [
		{
			"type": "equals",
			"field": "browser.browser_used",
			"value": true
		}
	]
}
