{
	"id": "browser_fallback_waf_blocked",
	"description": "Browser fallback triggers when WAF blocks the HTTP request (Cloudflare 403)",
	"tags": ["browser", "fallback", "waf"],
	"mock_response": {
		"status_code": 403,
		"headers": {
			"content-type": "text/html",
			"server": "cloudflare"
		},
		"body_file": "error/cloudflare_challenge.html"
	},
	"config": {
		"browser_mode": "auto"
	},
	"assertions": {
		"browser": {
			"browser_used": true
		}
	},
	"skip": {
		"requires_browser": true,
		"notes": "Requires a running Chrome/Chromium instance"
	}
}
