{
	"id": "browser_mode_always",
	"description": "Browser mode 'always' uses browser even for normal server-rendered pages",
	"tags": ["browser", "config"],
	"skip": {
		"languages": ["wasm", "c", "go", "java", "csharp"],
		"reason": "requires browser feature; requires browser; Requires a running Chrome/Chromium instance"
	},
	"input": {
		"mock_responses": [
			{
				"status_code": 200,
				"headers": {
					"content-type": "text/html; charset=utf-8"
				},
				"body_file": "html/basic_page.html"
			}
		],
		"config": {
			"browser_mode": "always"
		}
	},
	"assertions": [
		{
			"type": "equals",
			"field": "browser.browser_used",
			"value": true
		}
	]
}
