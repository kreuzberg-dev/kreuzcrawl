{
  "id": "browser_detect_normal_page",
  "description": "Does NOT flag a normal server-rendered page as needing JS rendering",
  "tags": ["browser", "detection"],
  "mock_response": {
    "status_code": 200,
    "headers": {"content-type": "text/html; charset=utf-8"},
    "body_file": "html/basic_page.html"
  },
  "assertions": {
    "status_code": 200,
    "browser": {
      "js_render_hint": false,
      "browser_used": false
    }
  }
}
