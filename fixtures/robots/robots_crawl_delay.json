{
	"id": "robots_crawl_delay",
	"description": "Respects crawl-delay directive from robots.txt",
	"tags": ["robots", "rate-limit"],
	"skip": {
		"languages": ["rust", "python", "node", "go", "java", "csharp", "ruby", "php", "elixir"],
		"reason": "mock server namespaces routes per fixture; robots.txt must be at server root"
	},
	"input": {
		"mock_responses": [
			{
				"status_code": 200,
				"headers": {
					"content-type": "text/plain"
				},
				"body_file": "robots/crawl_delay.txt"
			}
		],
		"config": {
			"respect_robots_txt": true,
			"user_agent": "kreuzcrawl"
		}
	},
	"assertions": [
		{
			"type": "equals",
			"field": "robots.crawl_delay",
			"value": 2
		}
	]
}
