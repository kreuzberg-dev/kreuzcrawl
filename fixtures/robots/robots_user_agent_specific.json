{
	"id": "robots_user_agent_specific",
	"description": "Matches user-agent specific rules in robots.txt",
	"tags": ["robots", "user-agent"],
	"skip": {
		"languages": ["rust", "python", "node", "go", "java", "csharp", "ruby", "php", "elixir"],
		"reason": "mock server namespaces routes per fixture; robots.txt must be at server root"
	},
	"input": {
		"mock_responses": [
			{
				"status_code": 200,
				"headers": {
					"content-type": "text/plain"
				},
				"body_file": "robots/user_agent_specific.txt"
			}
		],
		"config": {
			"respect_robots_txt": true,
			"user_agent": "KreuzcrawlBot"
		}
	},
	"assertions": [
		{
			"type": "equals",
			"field": "robots.is_allowed",
			"value": false
		}
	]
}
