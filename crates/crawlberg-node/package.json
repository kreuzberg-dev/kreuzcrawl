{
  "name": "@xberg-io/crawlberg",
  "version": "1.0.2",
  "description": "High-performance web crawling engine",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xberg-io/crawlberg.git"
  },
  "main": "index.js",
  "types": "index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "require": "./index.js",
      "default": "./index.js"
    }
  },
  "files": [
    "index.js",
    "index.d.ts",
    "*.node"
  ],
  "optionalDependencies": {
    "@xberg-io/crawlberg-darwin-arm64": "1.0.2",
    "@xberg-io/crawlberg-darwin-x64": "1.0.2",
    "@xberg-io/crawlberg-linux-arm64-gnu": "1.0.2",
    "@xberg-io/crawlberg-linux-arm64-musl": "1.0.2",
    "@xberg-io/crawlberg-linux-x64-gnu": "1.0.2",
    "@xberg-io/crawlberg-linux-x64-musl": "1.0.2",
    "@xberg-io/crawlberg-win32-arm64-msvc": "1.0.2",
    "@xberg-io/crawlberg-win32-x64-msvc": "1.0.2"
  },
  "napi": {
    "packageName": "@xberg-io/crawlberg",
    "binaryName": "crawlberg-node",
    "targets": [
      "x86_64-unknown-linux-gnu",
      "aarch64-unknown-linux-gnu",
      "x86_64-unknown-linux-musl",
      "aarch64-unknown-linux-musl",
      "x86_64-apple-darwin",
      "aarch64-apple-darwin",
      "x86_64-pc-windows-msvc",
      "aarch64-pc-windows-msvc"
    ]
  },
  "scripts": {
    "build": "npx --yes -p @napi-rs/cli@^3.6.2 napi build --platform --release",
    "artifacts": "npx --yes -p @napi-rs/cli@^3.6.2 napi artifacts",
    "prepublishOnly": "npx --yes -p @napi-rs/cli@^3.6.2 napi prepublish -t npm --skip-optional-publish"
  },
  "engines": {
    "node": ">= 22"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.7.2"
  }
}
