FROM rust:1-alpine AS builder
RUN apk add --no-cache musl-dev openssl-dev openssl-libs-static pkgconfig perl make
WORKDIR /src
COPY . .
RUN cargo build --release --manifest-path packages/elixir/native/kreuzcrawl_nif/Cargo.toml

FROM scratch
COPY --from=builder /src/target/release/libkreuzcrawl_nif.so /libkreuzcrawl_nif.so
