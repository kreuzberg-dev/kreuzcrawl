<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <RootNamespace>Kreuzcrawl</RootNamespace>
    <PackageId>Kreuzcrawl</PackageId>
    <Version>0.1.0</Version>
    <Authors>Na'aman Hirschfeld</Authors>
    <Company>kreuzberg.dev</Company>
    <Description>High-performance web crawling engine for .NET powered by Rust. Features async crawling, content scraping, and spider capabilities for efficient web data extraction.</Description>
    <PackageLicenseExpression>Elastic-2.0</PackageLicenseExpression>
    <PackageProjectUrl>https://kreuzberg.dev</PackageProjectUrl>
    <RepositoryUrl>https://github.com/kreuzberg-dev/kreuzcrawl</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageTags>crawl;scrape;web;spider;rust;ffi;dotnet</PackageTags>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
  </PropertyGroup>
</Project>
