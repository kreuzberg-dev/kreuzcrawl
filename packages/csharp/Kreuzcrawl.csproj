<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
    <PackageId>Kreuzcrawl</PackageId>
    <Version>0.1.0</Version>
    <Authors>Kreuzberg Team</Authors>
    <Description>High-performance web crawling engine - C# bindings</Description>
    <PackageLicenseExpression>Elastic-2.0</PackageLicenseExpression>
    <RepositoryUrl>https://github.com/kreuzberg-dev/kreuzcrawl</RepositoryUrl>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="xunit" Version="2.9.*" />
    <PackageReference Include="xunit.runner.visualstudio" Version="3.0.*" />
  </ItemGroup>
</Project>
