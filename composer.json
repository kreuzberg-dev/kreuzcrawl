{
  "name": "xberg-io/crawlberg",
  "description": "High-performance web crawling engine",
  "license": "MIT",
  "type": "php-ext",
  "require": {
    "php": ">=8.2"
  },
  "require-dev": {
    "phpunit/phpunit": "^13.1"
  },
  "autoload": {
    "psr-4": {
      "Crawlberg\\": "packages/php/src/"
    }
  },
  "scripts": {
    "format": "poly fmt --fix",
    "format:check": "poly fmt --check",
    "test": "php vendor/bin/phpunit",
    "lint": "poly lint",
    "lint:fix": "poly lint --fix && poly fmt --fix"
  },
  "php-ext": {
    "extension-name": "crawlberg",
    "support-zts": true,
    "support-nts": true,
    "download-url-method": "pre-packaged-binary"
  },
  "keywords": ["crawl", "scrape", "spider", "web"],
  "extra": {
    "pie": {
      "binary": {
        "url-template": "https://github.com/xberg-io/crawlberg/releases/download/{Version}/php_crawlberg-{Version}_php{PhpVersion}-{Arch}-{OSLower}-{Libc}-{TSMode}.tgz"
      }
    }
  }
}
